    "argon2": "^0.44.0",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "isbot": "^5.1.36",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.2",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "^4.2.1",
